{
  "name": "nuxt-template",
  "description": "Opinionated Nuxt Starter Template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"./src/**/*.{js,ts,vue,css}\"",
    "test": "vitest run",
    "unlighthouse": "unlighthouse"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.116",
    "@iconify-json/simple-icons": "^1.2.88",
    "@nuxt/content": "^3.15.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.9.0",
    "@vueuse/nuxt": "^14.3.0",
    "better-sqlite3": "^12.11.1",
    "date-fns": "^4.4.0",
    "nuxt": "^4.4.8",
    "reka-ui": "^2.10.1",
    "tailwindcss": "^4.3.2",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/hints": "^1.1.3",
    "@nuxt/test-utils": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "playwright-core": "^1.61.1",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "unlighthouse": "^0.18.0",
    "vitest": "^4.1.9",
    "vue-component-type-helpers": "^3.3.6"
  }
}
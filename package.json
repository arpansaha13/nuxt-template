{
  "name": "nuxt-template",
  "description": "Opinionated Nuxt Starter Template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"./src/**/*.{js,ts,vue,css}\"",
    "test": "vitest run",
    "unlighthouse": "unlighthouse"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.81",
    "@iconify-json/simple-icons": "^1.2.63",
    "@nuxt/content": "^3.9.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.3.0",
    "@vueuse/nuxt": "^14.1.0",
    "better-sqlite3": "^12.5.0",
    "nuxt": "^4.2.2",
    "reka-ui": "^2.6.1",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/test-utils": "^3.21.0",
    "@nuxtjs/html-validator": "^2.1.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.2",
    "happy-dom": "^20.0.11",
    "playwright-core": "^1.57.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "unlighthouse": "^0.17.4",
    "vitest": "^4.0.16",
    "vue-component-type-helpers": "^3.1.8"
  }
}